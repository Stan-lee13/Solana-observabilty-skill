{
  "title": "Solana Infrastructure Overview",
  "uid": "solana-infra",
  "tags": ["solana", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "panels": [
    {
      "title": "RPC Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "solana_rpc_healthy", "legendFormat": "{{endpoint}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "title": "Slot Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "solana_slot_lag", "legendFormat": "{{endpoint}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 25, "color": "yellow" }, { "value": 50, "color": "red" }] }
        }
      }
    },
    {
      "title": "RPC Latency P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(solana_rpc_latency_ms_bucket[5m]))", "legendFormat": "P95 {{endpoint}}" }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Transaction Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "rate(solana_tx_success_total[5m]) / (rate(solana_tx_success_total[5m]) + rate(solana_tx_failure_total[5m]))",
        "legendFormat": "Success Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 0.95, "color": "yellow" }, { "value": 0.995, "color": "green" }] }
        }
      }
    }
  ]
}
