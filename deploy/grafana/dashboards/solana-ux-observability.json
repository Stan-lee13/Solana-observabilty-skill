{
  "title": "Solana UX & Application Observability",
  "uid": "solana-ux",
  "tags": ["solana", "ux", "wallet", "frontend"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "wallet_adapter",
        "type": "query",
        "label": "Wallet Adapter",
        "datasource": "Prometheus",
        "query": "label_values(solana_wallet_error_total, wallet_name)",
        "current": {},
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "flow",
        "type": "query",
        "label": "User Flow",
        "datasource": "Prometheus",
        "query": "label_values(solana_user_journey_step_total, flow)",
        "current": {},
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Wallet Connection Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(solana_wallet_connection_total{status=\"success\",wallet_name=~\"$wallet_adapter\"}[5m])) / clamp_min(sum(rate(solana_wallet_connection_total{wallet_name=~\"$wallet_adapter\"}[5m])), 1)",
        "legendFormat": "Connection Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.9, "color": "yellow" },
              { "value": 0.98, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Transaction Sign → Confirm Latency P95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(solana_transaction_sign_to_confirm_seconds_bucket[5m])) by (le))",
        "legendFormat": "P95 Sign→Confirm"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "User Rejection Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(solana_wallet_error_total{category=\"user_rejected\"}[5m])) / clamp_min(sum(rate(solana_wallet_connection_total[5m])), 1)",
        "legendFormat": "Rejection Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.25, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Users (5m window)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "sum(solana_active_sessions_current)",
        "legendFormat": "Active Sessions"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "User Journey Funnel",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(solana_user_journey_step_total{step=\"wallet_connect\",flow=~\"$flow\"}[1h]))",
          "legendFormat": "1. Wallet Connect"
        },
        {
          "expr": "sum(rate(solana_user_journey_step_total{step=\"transaction_initiated\",flow=~\"$flow\"}[1h]))",
          "legendFormat": "2. Transaction Initiated"
        },
        {
          "expr": "sum(rate(solana_user_journey_step_total{step=\"user_signed\",flow=~\"$flow\"}[1h]))",
          "legendFormat": "3. User Signed"
        },
        {
          "expr": "sum(rate(solana_user_journey_step_total{step=\"transaction_confirmed\",flow=~\"$flow\"}[1h]))",
          "legendFormat": "4. Confirmed"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" } }
      }
    },
    {
      "id": 6,
      "title": "Wallet Errors by Category",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "sum by (category) (rate(solana_wallet_error_total{wallet_name=~\"$wallet_adapter\"}[5m]))",
        "legendFormat": "{{ category }}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 7,
      "title": "Sign → Confirm Latency Distribution",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [{
        "expr": "sum(rate(solana_transaction_sign_to_confirm_seconds_bucket[5m])) by (le)",
        "legendFormat": "{{ le }}"
      }],
      "options": { "calculate": false }
    },
    {
      "id": 8,
      "title": "Wallet Errors by Adapter (Top 5)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [{
        "expr": "topk(5, sum by (wallet_name) (rate(solana_wallet_error_total[1h])))",
        "legendFormat": "{{ wallet_name }}"
      }],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "title": "Synthetic Probe Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "solana_synthetic_rpc_probe_success",
          "legendFormat": "RPC: {{ endpoint }}"
        },
        {
          "expr": "solana_synthetic_instruction_success",
          "legendFormat": "Instruction: {{ instruction_name }}"
        },
        {
          "expr": "solana_synthetic_indexer_freshness_ok",
          "legendFormat": "Indexer: {{ indexer_name }}"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value": "Status" } } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILING", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
        ]}
      }
    },
    {
      "id": 10,
      "title": "Session Duration Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [{
        "expr": "sum(rate(solana_user_session_duration_seconds_bucket[1h])) by (le)",
        "legendFormat": "{{ le }}s"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
