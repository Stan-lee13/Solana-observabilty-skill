# =============================================================================
# .env.example — Solana Observability Stack
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── Required: RPC endpoints ──────────────────────────────────────────────────
# At least one RPC URL is required. Helius is recommended for production.
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_RPC_ALIAS=helius-primary

# Optional backup endpoints (exporter will failover automatically)
QUICKNODE_RPC_URL=
QUICKNODE_RPC_ALIAS=quicknode-backup
TRITON_RPC_URL=
TRITON_RPC_ALIAS=triton-fallback

# ── Cluster ──────────────────────────────────────────────────────────────────
# mainnet-beta | devnet | testnet
SOLANA_CLUSTER=mainnet-beta

# ── Scrape frequency ─────────────────────────────────────────────────────────
# How often to scrape on-chain metrics (minimum: 5 seconds)
SCRAPE_INTERVAL_SECONDS=15

# ── Addresses to monitor (comma-separated, no spaces) ────────────────────────
# Program IDs — monitor upgrade events, CU usage, tx success/failure
PROGRAM_IDS=

# Protocol vault addresses — monitor balance, drain rate
VAULT_ADDRESSES=

# Fee payer wallets — monitor balance, alert when low
FEE_PAYER_ADDRESSES=

# Governance token mints — monitor accumulation patterns
GOVERNANCE_MINTS=

# Bridge token mints — monitor wrapped supply vs locked collateral
BRIDGE_MINTS=

# DePIN node addresses — monitor status, stake, epoch rewards
DEPIN_NODE_ADDRESSES=

# ── Port overrides ────────────────────────────────────────────────────────────
EXPORTER_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093

# ── Prometheus storage ────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ── Grafana credentials ──────────────────────────────────────────────────────
# ⚠ CHANGE BEFORE PRODUCTION — this password is shown as an example only
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# ── Alert routing (optional) ─────────────────────────────────────────────────
# Enable Alertmanager profile: docker compose --profile alertmanager up -d
DISCORD_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=
